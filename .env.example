PORT=3000
SPREADSHEET_ID=PEGAR_ID_DE_LA_PLANILLA_INVENTARIO_VICTOR
GOOGLE_CLIENT_EMAIL=PEGAR_EMAIL_DE_LA_CUENTA_DE_SERVICIO
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPEGAR_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"

# Opcionales. ALLOWED_ORIGINS acepta varios dominios separados por coma.
ALLOWED_ORIGINS=https://TU-USUARIO.github.io

# Dejar vacío hasta que el frontend envíe x-api-key (se incorporará en la entrega frontend).
API_WRITE_KEY=

# Obligatoria para habilitar POST /reiniciar. Usar una clave larga y privada.
RESET_KEY=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_PRIVADA

# Modo administrador. Usar una clave privada y un secreto largo distinto.
ADMIN_KEY=CAMBIAR_POR_CLAVE_ADMINISTRATIVA
ADMIN_TOKEN_SECRET=CAMBIAR_POR_SECRETO_LARGO_ALEATORIO
